  <property name="styleSheet">
   <string notr="true">/* ============================================================
   GLOBAL QSS — TIMER PCP — Modern Dark Theme
   ============================================================ */

/* === BASE === */
QWidget {
    background-color: #1e1e1e;
    color: #e0e0e0;
    font-family: &quot;Segoe UI&quot;;
    font-size: 12px;
}

QMainWindow, QDialog {
    background-color: #1e1e1e;
}

/* === MENU BAR === */
QMenuBar {
    background-color: #161616;
    color: #e0e0e0;
    padding: 2px;
    border-bottom: 1px solid #2d2d2d;
}
QMenuBar::item:selected {
    background-color: #0078d4;
    border-radius: 3px;
}
QMenu {
    background-color: #252525;
    color: #e0e0e0;
    border: 1px solid #3a3a3a;
    padding: 4px 0px;
}
QMenu::item {
    padding: 6px 20px;
}
QMenu::item:selected {
    background-color: #0078d4;
}
QMenu::separator {
    height: 1px;
    background-color: #3a3a3a;
    margin: 4px 8px;
}

/* === TAB WIDGET === */
QTabWidget::pane {
    background-color: #252525;
    border: none;
    border-top: 2px solid #0078d4;
}
QTabBar {
    background-color: #161616;
}
QTabBar::tab {
    background-color: transparent;
    color: #aaaaaa;
    padding: 7px 18px;
    font-size: 12px;
    border: none;
    min-width: 70px;
}
QTabBar::tab:selected {
    background-color: #252525;
    color: #ffffff;
    font-weight: bold;
    border-top: 2px solid #0078d4;
}
QTabBar::tab:hover:!selected {
    background-color: rgba(255,255,255,0.06);
    color: #ffffff;
}

/* === BOUTONS === */
QPushButton {
    background-color: #2d2d2d;
    color: #e0e0e0;
    border: 1px solid #3a3a3a;
    border-radius: 5px;
    padding: 6px 14px;
    font-size: 12px;
}
QPushButton:hover {
    background-color: #0078d4;
    border-color: #0078d4;
    color: #ffffff;
}
QPushButton:pressed {
    background-color: #005a9e;
    border-color: #005a9e;
}
QPushButton:disabled {
    background-color: #1e1e1e;
    color: #555555;
    border-color: #2a2a2a;
}

/* === CHAMPS TEXTE === */
QLineEdit, QTextEdit, QPlainTextEdit {
    background-color: #2a2a2a;
    color: #e0e0e0;
    border: 1px solid #3a3a3a;
    border-radius: 4px;
    padding: 5px 8px;
    selection-background-color: #0078d4;
}
QLineEdit:focus, QTextEdit:focus, QPlainTextEdit:focus {
    border: 1px solid #0078d4;
}

/* === LABELS === */
QLabel {
    color: #e0e0e0;
    background-color: transparent;
}

/* === TABLEAUX === */
QTableWidget, QTableView {
    background-color: #252525;
    color: #e0e0e0;
    border: 1px solid #3a3a3a;
    gridline-color: #2d2d2d;
    selection-background-color: #0078d4;
    selection-color: #ffffff;
    alternate-background-color: #2a2a2a;
}
QTableWidget::item, QTableView::item {
    padding: 4px 6px;
}
QHeaderView::section {
    background-color: #1a1a1a;
    color: #aaaaaa;
    border: none;
    border-right: 1px solid #2d2d2d;
    border-bottom: 1px solid #3a3a3a;
    padding: 5px 8px;
    font-weight: bold;
    font-size: 11px;
}

/* === COMBOBOX === */
QComboBox {
    background-color: #2a2a2a;
    color: #e0e0e0;
    border: 1px solid #3a3a3a;
    border-radius: 4px;
    padding: 5px 8px;
}
QComboBox:hover {
    border-color: #0078d4;
}
QComboBox::drop-down {
    border: none;
    width: 20px;
}
QComboBox QAbstractItemView {
    background-color: #252525;
    color: #e0e0e0;
    border: 1px solid #3a3a3a;
    selection-background-color: #0078d4;
}

/* === SPINBOX === */
QSpinBox, QDoubleSpinBox {
    background-color: #2a2a2a;
    color: #e0e0e0;
    border: 1px solid #3a3a3a;
    border-radius: 4px;
    padding: 4px 6px;
}
QSpinBox:focus, QDoubleSpinBox:focus {
    border-color: #0078d4;
}

/* === CHECKBOX === */
QCheckBox {
    color: #e0e0e0;
    spacing: 8px;
    background-color: transparent;
}
QCheckBox::indicator {
    width: 16px;
    height: 16px;
    border: 1px solid #555555;
    border-radius: 3px;
    background-color: #2a2a2a;
}
QCheckBox::indicator:checked {
    background-color: #0078d4;
    border-color: #0078d4;
}
QCheckBox::indicator:hover {
    border-color: #0078d4;
}

/* === PROGRESS BAR === */
QProgressBar {
    background-color: #2a2a2a;
    border: 1px solid #3a3a3a;
    border-radius: 5px;
    text-align: center;
    color: #e0e0e0;
    font-size: 11px;
}
QProgressBar::chunk {
    background-color: #0078d4;
    border-radius: 4px;
}

/* === SCROLLBAR === */
QScrollBar:vertical {
    background-color: #1e1e1e;
    width: 10px;
    border: none;
}
QScrollBar::handle:vertical {
    background-color: #3a3a3a;
    border-radius: 5px;
    min-height: 30px;
}
QScrollBar::handle:vertical:hover {
    background-color: #0078d4;
}
QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
}
QScrollBar:horizontal {
    background-color: #1e1e1e;
    height: 10px;
    border: none;
}
QScrollBar::handle:horizontal {
    background-color: #3a3a3a;
    border-radius: 5px;
    min-width: 30px;
}
QScrollBar::handle:horizontal:hover {
    background-color: #0078d4;
}
QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    width: 0px;
}

/* === SEPARATEURS === */
QFrame[frameShape=&quot;4&quot;],
QFrame[frameShape=&quot;5&quot;] {
    color: #2d2d2d;
}

/* === GROUP BOX === */
QGroupBox {
    border: 1px solid #3a3a3a;
    border-radius: 6px;
    margin-top: 12px;
    padding-top: 8px;
    color: #aaaaaa;
    font-size: 11px;
}
QGroupBox::title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 4px;
}

/* === TOOLTIP === */
QToolTip {
    background-color: #2d2d2d;
    color: #e0e0e0;
    border: 1px solid #0078d4;
    border-radius: 3px;
    padding: 4px 8px;
}
</string>
