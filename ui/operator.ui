   <property name="styleSheet">
    <string notr="true">/* === BARRE D'ONGLETS (style Office Dark) === */
QTabWidget::pane {
    background-color: #2b2b2b;
    border: none;
    border-top: 2px solid #0078d4;
}

QTabBar {
    background-color: #161616;
}

QTabBar::tab {
    background-color: transparent;
    color: #cccccc;
    padding: 6px 16px;
    font-size: 12px;
    font-weight: normal;
    border: none;
    min-width: 60px;
}

QTabBar::tab:selected {
    background-color: #2b2b2b;
    color: #ffffff;
    font-weight: bold;
    border-top: 3px solid #0078d4;
}

QTabBar::tab:hover:!selected {
    background-color: rgba(255, 255, 255, 0.08);
    color: #ffffff;
}

QPushButton {
    background-color: transparent;
    color: #cccccc;
    border: 1px solid transparent;
    border-radius: 3px;
    padding: 4px 8px;
    font-size: 11px;
    min-width: 50px;
    min-height: 40px;
}

QPushButton:hover {
    background-color: #2d3a4f;
    border: 1px solid #0078d4;
    color: #ffffff;
}

QPushButton:pressed {
    background-color: #0078d4;
    border: 1px solid #005a9e;
    color: #ffffff;
}

QPushButton:disabled {
    color: #555555;
    background-color: transparent;
    border: none;
}

QLabel {
    color: #cccccc;
    font-size: 11px;
    background-color: transparent;
}

QWidget {
    background-color: #2b2b2b;
    color: #cccccc;
}

QFrame[frameShape=&quot;5&quot;] {
    color: #3a3a3a;
    max-width: 1px;
    margin: 4px 2px;
}
</string>
